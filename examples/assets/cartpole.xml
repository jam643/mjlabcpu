<mujoco model="cartpole">
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <worldbody>
    <body name="cart" pos="0 0 0.1">
      <joint name="slider" type="slide" axis="1 0 0" limited="true" range="-2.4 2.4"/>
      <geom name="cart_geom" type="box" size="0.15 0.075 0.05" rgba="0.2 0.4 0.7 1"/>
      <body name="pole" pos="0 0 0.1">
        <joint name="hinge" type="hinge" axis="0 1 0"/>
        <geom name="pole_geom" type="capsule" fromto="0 0 0 0 0 0.6" size="0.025" rgba="0.8 0.3 0.1 1"/>
        <body name="pole_tip" pos="0 0 0.6">
          <geom name="tip_geom" type="sphere" size="0.035" rgba="1 0 0 1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="slide" joint="slider" gear="100" ctrllimited="true" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
